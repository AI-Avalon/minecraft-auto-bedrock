{
  "name": "minecraft-auto-bedrock",
  "version": "1.0.0",
  "private": true,
  "description": "Java/Bedrock両対応の自律Mineflayer Bot",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "node setup.js",
    "start": "node src/index.js",
    "bootstrap": "node setup.js && node src/index.js",
    "configure:bedrock": "node scripts/configure-profile.js bedrock-avalox",
    "configure:java": "node scripts/configure-profile.js java-local",
    "configure:java-external": "node scripts/configure-profile.js java-external",
    "configure:mining-only": "node scripts/configure-profile.js mining-only",
    "configure:conversation-jp": "node scripts/configure-profile.js conversation-jp",
    "configure:multibot-sample": "node scripts/configure-profile.js multibot-sample",
    "server:install": "node scripts/mc-server-manager.js install",
    "server:start": "node scripts/mc-server-manager.js start",
    "server:bootstrap": "node scripts/mc-server-manager.js bootstrap",
    "bedrock:sync": "node scripts/sync-bedrock-samples.js",
    "doctor": "node scripts/system-doctor.js",
    "oneclick:setup": "node scripts/oneclick-setup.js",
    "gui": "node gui/server.js",
    "deploy": "node scripts/deploy.js",
    "test": "node --test test/full_system.test.js test/bedrock_data_service.test.js",
    "test:gui": "node --test test/gui.integration.test.js",
    "test:e2e": "node --test test/e2e.connection.test.js",
    "verify:all": "node setup.js && npm test && npm run test:gui && npm run test:e2e",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:save": "pm2 save"
  },
  "dependencies": {
    "express": "^4.21.2",
    "lowdb": "^7.0.1",
    "mineflayer": "^4.21.0",
    "mineflayer-auto-eat": "^5.0.0",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-movement": "^0.4.4",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "mineflayer-schem": "^1.2.0",
    "mineflayer-tool": "^1.2.0",
    "pm2": "^5.4.3",
    "prismarine-viewer": "^1.28.0",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  }
}
