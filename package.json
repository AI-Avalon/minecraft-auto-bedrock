{
  "name": "minecraft-auto-bedrock",
  "version": "2.0.0",
  "private": true,
  "description": "Java/Bedrock両対応の自律Mineflayer Bot - 状態機械AI・農業・探索・マルチサーバー対応",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "node setup.js",
    "start": "node src/index.js",
    "bootstrap": "node setup.js && node src/index.js",
    "configure:bedrock": "node scripts/configure-profile.js bedrock-avalox",
    "configure:java": "node scripts/configure-profile.js java-local",
    "configure:java-external": "node scripts/configure-profile.js java-external",
    "configure:mining-only": "node scripts/configure-profile.js mining-only",
    "configure:conversation-jp": "node scripts/configure-profile.js conversation-jp",
    "configure:multibot-sample": "node scripts/configure-profile.js multibot-sample",
    "configure:survival": "node scripts/configure-profile.js survival",
    "configure:farming": "node scripts/configure-profile.js farming",
    "server:install": "node scripts/mc-server-manager.js install",
    "server:start": "node scripts/mc-server-manager.js start",
    "server:bootstrap": "node scripts/mc-server-manager.js bootstrap",
    "server:selfhost": "node scripts/self-host-server.js",
    "server:selfhost:start": "node scripts/self-host-server.js start",
    "server:selfhost:stop": "node scripts/self-host-server.js stop",
    "bedrock:sync": "node scripts/sync-bedrock-samples.js",
    "doctor": "node scripts/system-doctor.js",
    "oneclick:setup": "node scripts/oneclick-setup.js",
    "gui": "node gui/server.js",
    "deploy": "node scripts/deploy.js",
    "test": "node --test test/full_system.test.js test/bedrock_data_service.test.js test/statemachine.test.js test/connection_diagnostics.test.js test/building_planner.test.js test/comprehensive.test.js",
    "test:comprehensive": "node --test test/comprehensive.test.js",
    "test:gui": "node --test test/gui.integration.test.js",
    "test:e2e": "node --test test/e2e.connection.test.js",
    "test:integration": "node --test test/integration/flying_squid_bot.test.js",
    "test:windows": "cmd /c run-tests.bat full",
    "verify:all": "node setup.js && npm test && npm run test:gui",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:save": "pm2 save",
    "ollama:setup": "node scripts/install-ollama.js",
    "ollama:setup:auto": "node scripts/install-ollama.js --auto",
    "ollama:check": "node scripts/install-ollama.js --check",
    "install:all": "node scripts/full-install.js",
    "install:all:auto": "node scripts/full-install.js --auto",
    "node:env": "node scripts/setup-node-env.js",
    "node:env:auto": "node scripts/setup-node-env.js --auto",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js --type=patch --yes",
    "release:minor": "node scripts/release.js --type=minor --yes",
    "release:major": "node scripts/release.js --type=major --yes",
    "release:notes": "python3 scripts/make-release-notes.py"
  },
  "dependencies": {
    "express": "^4.21.2",
    "minecraft-data": "^3.65.0",
    "minecraft-protocol": "^1.47.0",
    "mineflayer": "^4.21.0",
    "mineflayer-auto-eat": "^5.0.0",
    "mineflayer-collectblock": "^1.6.0",
    "mineflayer-movement": "^0.4.4",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "mineflayer-schem": "^1.2.0",
    "mineflayer-statemachine": "^1.2.2",
    "mineflayer-tool": "^1.2.0",
    "pm2": "^5.4.3",
    "prismarine-schematic": "^1.2.3",
    "prismarine-viewer": "^1.28.0",
    "simple-git": "^3.27.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "flying-squid": "^1.5.3"
  }
}
