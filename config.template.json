{
  "edition": "java",
  "bot": {
    "username": "AutoBedrockBot",
    "password": "",
    "auth": "offline",
    "reconnectDelayMs": 5000,
    "chatty": true
  },
  "java": {
    "host": "127.0.0.1",
    "port": 25565,
    "version": false
  },
  "localJavaServer": {
    "enabled": true,
    "autoStart": false,
    "software": "paper",
    "minecraftVersion": "1.21.4",
    "forgeVersion": "",
    "directory": "local-server",
    "javaPath": "java",
    "xms": "1G",
    "xmx": "2G",
    "nogui": true,
    "eula": true
  },
  "connectionPolicy": {
    "allowExternalServers": true,
    "allowLocalhost": true,
    "allowedHosts": []
  },
  "behavior": {
    "mode": "hybrid"
  },
  "combat": {
    "healThreshold": 10,
    "retreatThreshold": 8,
    "rangedPreferDistance": 9,
    "meleeMaxDistance": 3
  },
  "chatControl": {
    "enabled": true,
    "requirePrefix": true,
    "commandPrefix": "!bot",
    "allowAllPlayers": true,
    "allowedPlayers": [],
    "playerRoles": {
      "owner_name": "admin"
    },
    "dangerousCommands": [
      "mode",
      "stop",
      "retreat",
      "base",
      "fight",
      "fightmob"
    ]
  },
  "llm": {
    "enabled": false,
    "provider": "ollama",
    "baseUrl": "http://127.0.0.1:11434",
    "model": "qwen2.5:3b",
    "timeoutMs": 12000,
    "fallbackRuleBased": true
  },
  "bedrockKnowledge": {
    "enabled": true,
    "samplesPath": "data/bedrock-samples"
  },
  "multiBot": {
    "enabled": false,
    "bots": [
      {
        "id": "miner-1",
        "role": "primary",
        "username": "AutoMiner1",
        "memoryFile": "memory-miner-1.json",
        "behavior": {
          "mode": "silent-mining"
        }
      },
      {
        "id": "assistant-1",
        "role": "assistant",
        "username": "AutoAssist1",
        "memoryFile": "memory-assistant-1.json",
        "behavior": {
          "mode": "conversation"
        }
      }
    ]
  },
  "bedrock": {
    "host": "YOUR_BEDROCK_SERVER_HOST",
    "port": 19132,
    "waitForTicks": 4,
    "proxy": {
      "enabled": true,
      "enableAutoDownload": true,
      "enableAutoStart": true,
      "listenHost": "127.0.0.1",
      "listenPort": 25566,
      "targetVersion": "bedrocklatest",
      "authMethod": "none",
      "jarPath": "bin/ViaProxy.jar",
      "githubRepo": "ViaVersion/ViaProxy",
      "fixedVersion": "",
      "args": []
    }
  },
  "memory": {
    "file": "memory.json",
    "maxRecords": 5000,
    "maxHistoryPerChest": 30
  },
  "gui": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 3000,
    "security": {
      "requireToken": false,
      "token": "",
      "readOnly": false,
      "allowedCommands": [
        "set-base",
        "collect",
        "build",
        "build-with-refill",
        "fetch-item",
        "retreat-base",
        "start-auto-collect",
        "stop-auto-collect",
        "start-auto-mine",
        "stop-auto-mine",
        "fleet-add-bot",
        "fleet-remove-bot",
        "fleet-update-role",
        "fight-nearest-mob",
        "fight-player",
        "stop-fight",
        "planner-calc-recipe",
        "planner-gather-for-craft",
        "orchestrator-assign-task"
      ],
      "commandCooldownMs": 800,
      "maxCommandsPerMinute": 20,
      "auditLogFile": "logs/gui-audit.log"
    }
  },
  "automation": {
    "autoGitPush": false,
    "commitIntervalMinutes": 30,
    "commitMessagePrefix": "自動更新"
  },
  "extensions": {
    "discordWebhookUrl": ""
  }
}
