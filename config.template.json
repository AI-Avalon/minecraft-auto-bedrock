{
  "edition": "java",
  "bot": {
    "username": "AutoBedrockBot",
    "password": "",
    "auth": "offline",
    "reconnectDelayMs": 5000,
    "chatty": true
  },
  "java": {
    "host": "127.0.0.1",
    "port": 25565,
    "version": false
  },
  "localJavaServer": {
    "enabled": true,
    "autoStart": false,
    "software": "paper",
    "minecraftVersion": "1.21.4",
    "forgeVersion": "",
    "directory": "local-server",
    "javaPath": "java",
    "xms": "1G",
    "xmx": "2G",
    "nogui": true,
    "eula": true
  },
  "bedrock": {
    "host": "YOUR_BEDROCK_SERVER_HOST",
    "port": 19132,
    "waitForTicks": 4,
    "proxy": {
      "enabled": true,
      "enableAutoDownload": true,
      "enableAutoStart": true,
      "listenHost": "127.0.0.1",
      "listenPort": 25566,
      "targetVersion": "bedrocklatest",
      "authMethod": "none",
      "jarPath": "bin/ViaProxy.jar",
      "githubRepo": "ViaVersion/ViaProxy",
      "fixedVersion": "",
      "args": []
    }
  },
  "memory": {
    "file": "memory.json",
    "maxRecords": 5000,
    "maxHistoryPerChest": 30
  },
  "gui": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 3000,
    "security": {
      "requireToken": false,
      "token": "",
      "readOnly": false,
      "allowedCommands": [
        "set-base",
        "collect",
        "build",
        "build-with-refill",
        "fetch-item",
        "retreat-base",
        "start-auto-collect",
        "stop-auto-collect",
        "start-auto-mine",
        "stop-auto-mine"
      ],
      "commandCooldownMs": 800,
      "maxCommandsPerMinute": 20,
      "auditLogFile": "logs/gui-audit.log"
    }
  },
  "automation": {
    "autoGitPush": false,
    "commitIntervalMinutes": 30,
    "commitMessagePrefix": "自動更新"
  },
  "extensions": {
    "discordWebhookUrl": ""
  }
}
